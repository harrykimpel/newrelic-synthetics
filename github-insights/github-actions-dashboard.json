{
  "name": "GitHub Actions Metrics",
  "description": "Overview and details of GitHub Actions workflow runs and job executions. Powered by GitHubActionsWorkflowRun and GitHubActionsJob custom events.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Overview",
      "description": "High-level summary of GitHub Actions usage",
      "widgets": [
        {
          "title": "Total Workflow Runs",
          "layout": { "column": 1, "row": 1, "width": 3, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) AS 'Workflow Runs' FROM GitHubActionsWorkflowRun SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Total Job Runs",
          "layout": { "column": 4, "row": 1, "width": 3, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) AS 'Job Runs' FROM GitHubActionsJob SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Raw Minutes Used",
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT sum(durationMs) / 60000 AS 'Raw Minutes' FROM GitHubActionsJob SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "GitHub Billing Minutes",
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT sum(billingMinutes) AS 'Billing Minutes' FROM GitHubActionsJob SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Success Rate",
          "layout": { "column": 1, "row": 4, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT percentage(count(*), WHERE conclusion = 'success') AS 'Success Rate %' FROM GitHubActionsWorkflowRun SINCE 7 days ago" }],
            "thresholds": [
              { "alertSeverity": "CRITICAL", "value": 80 },
              { "alertSeverity": "WARNING", "value": 90 }
            ],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Avg Job Duration",
          "layout": { "column": 5, "row": 4, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT average(durationMs) / 60000 AS 'Avg Duration (min)' FROM GitHubActionsJob SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Failed Runs",
          "layout": { "column": 9, "row": 4, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) AS 'Failed Runs' FROM GitHubActionsWorkflowRun WHERE conclusion = 'failure' SINCE 7 days ago" }],
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 1 },
              { "alertSeverity": "CRITICAL", "value": 5 }
            ],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Workflow Runs Over Time",
          "layout": { "column": 1, "row": 7, "width": 8, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.area" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) FROM GitHubActionsWorkflowRun FACET conclusion TIMESERIES AUTO SINCE 7 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Runs by Conclusion",
          "layout": { "column": 9, "row": 7, "width": 4, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.pie" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) FROM GitHubActionsWorkflowRun FACET conclusion SINCE 7 days ago LIMIT 10" }],
            "facet": { "showOtherSeries": true },
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Top Workflows by Run Count",
          "layout": { "column": 1, "row": 10, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) FROM GitHubActionsWorkflowRun FACET workflowName SINCE 7 days ago LIMIT 20" }],
            "facet": { "showOtherSeries": false },
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Jobs by Status",
          "layout": { "column": 7, "row": 10, "width": 6, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT count(*) FROM GitHubActionsJob FACET conclusion SINCE 7 days ago LIMIT 10" }],
            "facet": { "showOtherSeries": false },
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Minutes Used per Day",
          "layout": { "column": 1, "row": 13, "width": 12, "height": 3 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT sum(durationMs) / 60000 AS 'Minutes' FROM GitHubActionsJob TIMESERIES SINCE 30 days ago" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        },
        {
          "title": "Recent Failed Runs",
          "layout": { "column": 1, "row": 16, "width": 12, "height": 4 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT workflowName, branch, actor, conclusion, durationMs / 60000 AS 'Duration (min)', createdAt FROM GitHubActionsWorkflowRun WHERE conclusion = 'failure' OR conclusion = 'cancelled' OR conclusion = 'timed_out' SINCE 7 days ago LIMIT 50" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
        }
      ]
    },
