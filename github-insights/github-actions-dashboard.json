          }
        },
        {
          "title": "All Workflow Runs",
          "layout": { "column": 1, "row": 10, "width": 12, "height": 5 },
          "linkedEntityGuids": null,
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [{ "accountIds": [NR_ACCOUNT_ID], "query": "SELECT runId, workflowName, branch, actor, triggerEvent, status, conclusion, durationMs / 60000 AS 'Duration (min)', createdAt FROM GitHubActionsWorkflowRun SINCE 30 days ago LIMIT 200" }],
            "platformOptions": { "ignoreTimeWindow": false }
          }
